{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.luoxia.engine/contracts/materialization.v1.schema.json",
  "title": "Luoxia Materialization Contract v1",
  "oneOf": [
    {
      "$ref": "#/$defs/MaterializationRequest"
    },
    {
      "$ref": "#/$defs/AssetCandidate"
    },
    {
      "$ref": "#/$defs/ReviewReceipt"
    },
    {
      "$ref": "#/$defs/AssetAcceptance"
    },
    {
      "$ref": "#/$defs/VisualBinding"
    },
    {
      "$ref": "#/$defs/PromotionDecision"
    }
  ],
  "$defs": {
    "ProfileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_id",
        "bundle_digest",
        "profile_id"
      ],
      "properties": {
        "bundle_id": {
          "$ref": "common.v1.schema.json#/$defs/NamespacedIdentifier"
        },
        "bundle_digest": {
          "$ref": "common.v1.schema.json#/$defs/Sha256"
        },
        "profile_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        }
      }
    },
    "MaterializationRequestDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "world_id",
        "subject",
        "subject_revision",
        "slot_id",
        "materialization_profile",
        "art_profile",
        "generation_spec_digest",
        "reuse_scopes",
        "fallback"
      ],
      "properties": {
        "request_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "world_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "subject": {
          "$ref": "common.v1.schema.json#/$defs/SubjectRef"
        },
        "subject_revision": {
          "type": "integer",
          "minimum": 0
        },
        "slot_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "materialization_profile": {
          "$ref": "#/$defs/ProfileRef"
        },
        "art_profile": {
          "$ref": "#/$defs/ProfileRef"
        },
        "generation_spec_digest": {
          "$ref": "common.v1.schema.json#/$defs/Sha256"
        },
        "reuse_scopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "session",
              "pack",
              "reviewed_shared"
            ]
          }
        },
        "fallback": {
          "$ref": "common.v1.schema.json#/$defs/AssetContentRef"
        }
      }
    },
    "MaterializationRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "record_type",
        "request_id",
        "world_id",
        "subject",
        "subject_revision",
        "slot_id",
        "materialization_profile",
        "art_profile",
        "generation_spec_digest",
        "reuse_scopes",
        "fallback",
        "requested_by_event_id",
        "status"
      ],
      "properties": {
        "contract_version": {
          "const": "materialization.v1"
        },
        "record_type": {
          "const": "materialization.request"
        },
        "request_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "world_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "subject": {
          "$ref": "common.v1.schema.json#/$defs/SubjectRef"
        },
        "subject_revision": {
          "type": "integer",
          "minimum": 0
        },
        "slot_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "materialization_profile": {
          "$ref": "#/$defs/ProfileRef"
        },
        "art_profile": {
          "$ref": "#/$defs/ProfileRef"
        },
        "generation_spec_digest": {
          "$ref": "common.v1.schema.json#/$defs/Sha256"
        },
        "reuse_scopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "session",
              "pack",
              "reviewed_shared"
            ]
          }
        },
        "fallback": {
          "$ref": "common.v1.schema.json#/$defs/AssetContentRef"
        },
        "requested_by_event_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "status": {
          "enum": [
            "pending",
            "searching",
            "generating",
            "reviewing",
            "accepted",
            "failed",
            "superseded"
          ]
        }
      }
    },
    "AssetCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "record_type",
        "candidate_id",
        "request_id",
        "subject_revision",
        "generation_spec_digest",
        "asset",
        "storage_locator",
        "provider_receipt_digest",
        "created_at",
        "provenance"
      ],
      "properties": {
        "contract_version": {
          "const": "materialization.v1"
        },
        "record_type": {
          "const": "asset.candidate"
        },
        "candidate_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "request_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "subject_revision": {
          "type": "integer",
          "minimum": 0
        },
        "generation_spec_digest": {
          "$ref": "common.v1.schema.json#/$defs/Sha256"
        },
        "asset": {
          "$ref": "common.v1.schema.json#/$defs/AssetContentRef"
        },
        "storage_locator": {
          "type": "string",
          "format": "uri",
          "maxLength": 2048
        },
        "provider_receipt_digest": {
          "$ref": "common.v1.schema.json#/$defs/Sha256"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "provenance": {
          "$ref": "common.v1.schema.json#/$defs/Provenance"
        }
      }
    },
    "ReviewCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "verdict"
      ],
      "properties": {
        "check_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "verdict": {
          "enum": [
            "pass",
            "fail",
            "not_applicable"
          ]
        },
        "evidence_digest": {
          "$ref": "common.v1.schema.json#/$defs/Sha256"
        },
        "note": {
          "type": "string",
          "maxLength": 4000
        }
      }
    },
    "ReviewReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "record_type",
        "review_id",
        "candidate_id",
        "verdict",
        "checks",
        "reviewer_kind",
        "reviewer_id",
        "reviewed_at"
      ],
      "properties": {
        "contract_version": {
          "const": "materialization.v1"
        },
        "record_type": {
          "const": "asset.review"
        },
        "review_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "candidate_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "verdict": {
          "enum": [
            "accepted",
            "rejected"
          ]
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ReviewCheck"
          }
        },
        "reviewer_kind": {
          "enum": [
            "policy",
            "human"
          ]
        },
        "reviewer_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "AssetAcceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "record_type",
        "acceptance_id",
        "request_id",
        "candidate_id",
        "subject_revision",
        "asset",
        "review_id",
        "accepted_at"
      ],
      "properties": {
        "contract_version": {
          "const": "materialization.v1"
        },
        "record_type": {
          "const": "asset.acceptance"
        },
        "acceptance_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "request_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "candidate_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "subject_revision": {
          "type": "integer",
          "minimum": 0
        },
        "asset": {
          "$ref": "common.v1.schema.json#/$defs/AssetContentRef"
        },
        "review_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "accepted_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "VisualBindingDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "world_id",
        "subject",
        "subject_revision",
        "slot_id",
        "asset",
        "scope",
        "state"
      ],
      "properties": {
        "binding_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "world_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "subject": {
          "$ref": "common.v1.schema.json#/$defs/SubjectRef"
        },
        "subject_revision": {
          "type": "integer",
          "minimum": 0
        },
        "slot_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "asset": {
          "$ref": "common.v1.schema.json#/$defs/AssetContentRef"
        },
        "source_request_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "acceptance_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "scope": {
          "const": "session"
        },
        "state": {
          "const": "active"
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "source_request_id"
            ]
          },
          "then": {
            "required": [
              "acceptance_id"
            ]
          }
        }
      ]
    },
    "VisualBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "record_type",
        "binding_id",
        "world_id",
        "subject",
        "subject_revision",
        "slot_id",
        "asset",
        "scope",
        "created_by_event_id",
        "state"
      ],
      "properties": {
        "contract_version": {
          "const": "materialization.v1"
        },
        "record_type": {
          "const": "visual.binding"
        },
        "binding_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "world_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "subject": {
          "$ref": "common.v1.schema.json#/$defs/SubjectRef"
        },
        "subject_revision": {
          "type": "integer",
          "minimum": 0
        },
        "slot_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "asset": {
          "$ref": "common.v1.schema.json#/$defs/AssetContentRef"
        },
        "source_request_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "acceptance_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "scope": {
          "const": "session"
        },
        "created_by_event_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "state": {
          "enum": [
            "active",
            "retired"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "source_request_id"
            ]
          },
          "then": {
            "required": [
              "acceptance_id"
            ]
          }
        }
      ]
    },
    "PromotionDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_version",
        "record_type",
        "decision_id",
        "binding_id",
        "from_scope",
        "to_scope",
        "verdict",
        "reviewer_id",
        "decided_at"
      ],
      "properties": {
        "contract_version": {
          "const": "materialization.v1"
        },
        "record_type": {
          "const": "asset.promotion"
        },
        "decision_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "binding_id": {
          "$ref": "common.v1.schema.json#/$defs/Uuid"
        },
        "from_scope": {
          "const": "session"
        },
        "to_scope": {
          "enum": [
            "pack",
            "reviewed_shared"
          ]
        },
        "verdict": {
          "enum": [
            "accepted",
            "rejected"
          ]
        },
        "reviewer_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "decided_at": {
          "type": "string",
          "format": "date-time"
        },
        "reason": {
          "type": "string",
          "maxLength": 4000
        }
      }
    }
  }
}
