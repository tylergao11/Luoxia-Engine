          "type": "array",
          "items": {
            "$ref": "#/$defs/MachineTransitionDefinition"
          }
        },
        "advance_resolver": {
          "$ref": "#/$defs/PluginOperationRef"
        },
        "fields": {
          "$ref": "#/$defs/FieldValues"
        }
      }
    },
    "InitialMachineBinding": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "binding_kind",
            "binding_id",
            "entity_id",
            "machine_id"
          ],
          "properties": {
            "binding_kind": {
              "const": "character"
            },
            "binding_id": {
              "$ref": "common.v1.schema.json#/$defs/Identifier"
