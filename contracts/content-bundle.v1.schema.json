            "entity_id": {
              "$ref": "common.v1.schema.json#/$defs/Identifier"
            },
            "machine_id": {
              "$ref": "common.v1.schema.json#/$defs/Identifier"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "binding_kind",
            "binding_id",
            "world_id",
            "machine_id"
          ],
          "properties": {
            "binding_kind": {
              "const": "world"
            },
            "binding_id": {
              "$ref": "common.v1.schema.json#/$defs/Identifier"
            },
            "world_id": {
              "$ref": "common.v1.schema.json#/$defs/Identifier"
            },
            "machine_id": {
              "$ref": "common.v1.schema.json#/$defs/Identifier"
            }
          }
        }
      ]
    },
    "CharacterMindProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mind_id",
        "entity_id",
        "persona_prompt_ids",
        "dialogue_prompt_id",
        "reaction_prompt_id",
        "fields"
      ],
      "properties": {
        "mind_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "entity_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "persona_prompt_ids": {
          "type": "array",
          "items": {
            "$ref": "common.v1.schema.json#/$defs/Identifier"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "dialogue_prompt_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "reaction_prompt_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "fields": {
          "$ref": "#/$defs/FieldValues"
        }
