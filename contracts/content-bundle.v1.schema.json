      "properties": {
        "daily_capacity": {
          "type": "integer",
          "minimum": 0
        },
        "card_cost_resolver": {
          "$ref": "#/$defs/PluginOperationRef"
        },
        "cost_parameters": {
          "$ref": "common.v1.schema.json#/$defs/JsonObject"
        }
      }
    }
  }
}
