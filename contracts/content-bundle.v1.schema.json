        "from_bundle_digest",
        "to_pack_version",
        "transformer",
        "description",
        "requires_player_consent"
      ],
      "properties": {
        "migration_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "from_pack_version": {
          "$ref": "common.v1.schema.json#/$defs/SemVer"
        },
        "from_bundle_digest": {
          "$ref": "common.v1.schema.json#/$defs/Sha256"
        },
        "to_pack_version": {
          "$ref": "common.v1.schema.json#/$defs/SemVer"
        },
        "transformer": {
          "$ref": "#/$defs/PluginOperationRef"
        },
        "description": {
          "$ref": "common.v1.schema.json#/$defs/LocalizedText"
        },
        "requires_player_consent": {
          "type": "boolean"
        }
      }
    },
    "MachineStateDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_id",
        "name",
