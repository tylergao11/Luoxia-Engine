        "from_state_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "to_state_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "trigger_type": {
          "$ref": "common.v1.schema.json#/$defs/NamespacedIdentifier"
        },
        "guard": {
          "$ref": "common.v1.schema.json#/$defs/RuleRef"
        },
        "fields": {
          "$ref": "#/$defs/FieldValues"
        }
      }
    },
    "StateMachineDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "machine_id",
        "world_id",
        "machine_scope",
        "name",
        "initial_state_id",
        "states",
        "transitions",
        "advance_resolver",
        "fields"
      ],
      "properties": {
        "machine_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "world_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "machine_scope": {
          "enum": [
