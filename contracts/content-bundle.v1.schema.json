            "$ref": "common.v1.schema.json#/$defs/Identifier"
          }
        },
        "daily_settlement_prompt_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "dialogue_events_prompt_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "system_dialogue_prompt_id": {
          "$ref": "common.v1.schema.json#/$defs/Identifier"
        },
        "fields": {
          "$ref": "#/$defs/FieldValues"
        }
      }
    },
    "Simulation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_machines",
        "initial_machine_bindings",
        "character_minds",
        "director_profiles"
      ],
      "properties": {
        "state_machines": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StateMachineDefinition"
          },
          "minItems": 1
        },
        "initial_machine_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/InitialMachineBinding"
          },
          "minItems": 1
        },
        "character_minds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CharacterMindProfile"
          }
        },
        "director_profiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DirectorProfile"
          },
